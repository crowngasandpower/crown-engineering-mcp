# Required for the review-api service.
# Get a key from console.anthropic.com (or use the org-shared key if you have access).
ANTHROPIC_API_KEY=

# Required for the unleash-api service.
# Global admin token from the Unleash admin UI (format: user:<hex>).
UNLEASH_ADMIN_TOKEN=
# Optional overrides; defaults match the current Crown Unleash instance.
# UNLEASH_BASE_URL=https://eu.app.getunleash.io/eull0051
# UNLEASH_PROJECT=core-products

# Required for the bugs-api service (and unleash-api Jira features).
# Jira Cloud email + API token for the service account.
JIRA_EMAIL=
JIRA_API_TOKEN=
# Optional overrides:
# JIRA_BASE_URL=https://crowngasandpower-team-delivery.atlassian.net
# JIRA_PROJECT=CT
